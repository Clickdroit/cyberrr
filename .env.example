# ══════════════════════════════════════════════════════
#  OSINT Hub — Environment Variables
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════

# ── AUTHENTIFICATION ───────────────────────────────────
# Mot de passe unique pour accéder au site web
# !! Changer absolument avant le déploiement !!
ACCESS_PASSWORD=votre_mot_de_passe_tres_fort_ici

# Clé secrète pour signer les cookies de session (32+ caractères aléatoires)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_moi_avec_une_vraie_cle_aleatoire_de_32_chars

# ── RÉSEAU ────────────────────────────────────────────
# Port exposé sur le VPS (80 = HTTP, 443 si SSL terminé ailleurs)
PORT=80

# Mettre 'true' si HTTPS activé (active le flag Secure sur le cookie)
HTTPS_ENABLED=false

# ── BASE DE DONNÉES ───────────────────────────────────
# Chemin interne Docker (ne pas modifier sauf raison spécifique)
DB_PATH=/data/db/osint.db

# ── REDIS ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OUTILS OSINT ──────────────────────────────────────
# Dossier où sont stockés les rapports temporaires des outils
REPORTS_DIR=/data/reports

# Chemin vers les cookies GHunt (si configuré)
# Pour configurer GHunt : entrer dans le container et lancer "ghunt login"
GHUNT_COOKIES_PATH=/app/config/ghunt_cookies.json

# Clé API HaveIBeenPwned (facultative)
# Si non configuré, l'application simulera des fuites crédibles pour illustration
HIBP_API_KEY=

# ── RESEAU & SECURITE (AVANCES) ────────────────────────
# Proxy global (HTTP ou SOCKS5) pour les requêtes sortantes (ex. Tor)
# PROXY_URL=socks5://tor:9050

# ── NOTIFICATIONS & WEBHOOKS ──────────────────────────
# Discord Webhook pour recevoir un résumé à chaque scan terminé
DISCORD_WEBHOOK_URL=

# Bot Telegram pour alertes (les deux doivent être remplis)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

